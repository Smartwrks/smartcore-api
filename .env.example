# ---- Server ----
PORT=3002
ALLOWED_ORIGINS=http://localhost:5173,https://smartcore360.com

# ---- Supabase ----
# SUPABASE_SERVICE_KEY bypasses RLS — server-side only, NEVER ship to the browser.
# SUPABASE_ANON_KEY is used solely to verify caller JWTs (we don't query through it).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# ---- Vector store ----
# Default Pinecone index host — accounts use this unless their
# account_provisioning row sets vector_index_host to override.
PINECONE_API_KEY=
PINECONE_HOST_DEFAULT=

# ---- LLM providers (only the ones you use need to be set) ----
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
